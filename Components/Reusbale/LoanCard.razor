@using BlazorApp.Models;

<div class="loan-card">
    <div class="loan-icon"><i class="@Icon"></i></div>
    <h3>@Title</h3>
    <div class="loan-desc">@Description</div>
    <div class="loan-meta">
        <span class="loan-rate">@SmallDescription</span>
        <button class="btn-apply" disabled><i class="bi bi-send"></i> Apply</button>
    </div>
</div>

@code{
    [Parameter] public string Title{get;set;}="";
    [Parameter] public string Description{get;set;}="";
    [Parameter] public string Icon{get;set;}="";
    [Parameter] public string SmallDescription{get;set;}="";
    [Parameter] public LoanTypes LoanType{get;set;} = LoanTypes.None;

    private string LoanApplicationUrl(){
        if(LoanType == LoanTypes.None) return "/applications/create";

        switch(LoanType){
            case LoanTypes.Personal:
                return "/applications/create/5673";
            case LoanTypes.Home:
                return "/applications/create/5674";
            case LoanTypes.Car:
                return "/applications/create/5675";
        }

        return "";
    }

}