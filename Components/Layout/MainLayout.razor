@inherits LayoutComponentBase

<div class="layout">

    <aside class="sidebar">
        <NavMenu />
    </aside>

    <div class="main">

        <header class="topbar">

            <div class="page-title">
                <h3>RockSolid</h3>
            </div>

            <div class="top-actions">

                <a class="about" href="https://learn.microsoft.com/aspnet/core/" target="_blank">
                    <i class="bi bi-question-circle"></i>
                    About
                </a>

                <AuthorizeView>

                    <NotAuthorized>

                        <a class="login" href="/login">
                            <i class="bi bi-box-arrow-in-right"></i>
                            Login
                        </a>

                    </NotAuthorized>

                    <Authorized>

                        <a class="logout" href="/logout">
                            <i class="bi bi-box-arrow-right"></i>
                            Logout
                        </a>

                    </Authorized>

                </AuthorizeView>

            </div>

        </header>

        <main class="page-content">

            @Body

        </main>

    </div>

</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href=".">Reload</a>
</div>