    private List<ApplicationViewModel> GetFilteredApplications()
    {
        var query = Applications.AsQueryable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            query = query.Where(a => 
                a.ApplicantName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                a.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                a.ApplicationId.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                a.Phone.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        // Apply quick filter
        if (quickFilter != "all")
        {
            var statusMapping = new Dictionary<string, string>
            {
                ["pending"] = "Pending",
                ["approved"] = "Approved",
                ["rejected"] = "Rejected",
                ["inprogress"] = "In Progress"
            };
            if (statusMapping.ContainsKey(quickFilter))
            {
                query = query.Where(a => a.Status == statusMapping[quickFilter]);
            }
        }

        // Apply loan type filter
        if (loanTypeFilter != "all")
        {
            var typeMapping = new Dictionary<string, string>
            {
                ["personal"] = "Personal Loan",
                ["home"] = "Home Loan",
                ["car"] = "Car Loan"
            };
            if (typeMapping.ContainsKey(loanTypeFilter))
            {
                query = query.Where(a => a.LoanType == typeMapping[loanTypeFilter]);
            }
        }

        // Apply amount range filter
        if (amountRange != "all")
        {
            query = amountRange switch
            {
                "0-10000" => query.Where(a => a.AmountApplied <= 10000),
                "10000-50000" => query.Where(a => a.AmountApplied > 10000 && a.AmountApplied <= 50000),
                "50000-100000" => query.Where(a => a.AmountApplied > 50000 && a.AmountApplied <= 100000),
                "100000+" => query.Where(a => a.AmountApplied > 100000),
                _ => query
            };
        }

        // Apply date range filter
        @* if (!string.IsNullOrEmpty(dateFrom))
        {
            if (DateTime.TryParse(dateFrom, out var fromDate))
            {
                query = query.Where(a => a.ApplicationDate >= fromDate);
            }
        }
        if (!string.IsNullOrEmpty(dateTo))
        {
            if (DateTime.TryParse(dateTo, out var toDate))
            {
                query = query.Where(a => a.ApplicationDate <= toDate);
            }
        } *@

        // Apply sorting (newest first)
        query = query.OrderByDescending(a => a.ApplicationDate);

        // Apply pagination
        var filtered = query.ToList();
        totalPages = (int)Math.Ceiling((double)filtered.Count / pageSize);
        
        return filtered
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void UpdatePagination()
    {
        var totalItems = Applications.Count;
        totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
        }
    }

    private void ResetFilters()
    {
        searchTerm = "";
        loanTypeFilter = "all";
        amountRange = "all";
        dateFrom = new DateTime();
        dateTo = new DateTime();
        quickFilter = "all";
        currentPage = 1;
    }

    private void SetQuickFilter(string filter)
    {
        quickFilter = filter;
        currentPage = 1;
    }

    private void ToggleDetails(Guid id)
    {
        if (expandedApplications.Contains(id))
            expandedApplications.Remove(id);
        else
            expandedApplications.Add(id);
    }

    private int GetProgressPercentage(string status)
    {
        return status switch
        {
            "Pending" => 25,
            "In Progress" => 50,
            "Approved" => 100,
            "Rejected" => 100,
            _ => 0
        };
    }

    private int GetProcessingDays(ApplicationViewModel app)
    {
        if (app.Status == "Pending" || app.Status == "In Progress")
        {
            return (int)(DateTime.Now - app.ApplicationDate).TotalDays;
        }
        return 0;
    }

    private void ApproveApplication(ApplicationViewModel app)
    {
        app.Status = "Approved";
    }

    private void RejectApplication(ApplicationViewModel app)
    {
        app.Status = "Rejected";
    }

