    private List<InstallmentViewModel> GetFilteredInstallments()
    {
        var query = Installments.AsQueryable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            query = query.Where(i => 
                i.ClientName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                i.LoanReference.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                i.LoanType.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        // Apply status filter
        if (statusFilter != "all")
        {
            query = query.Where(i => 
                i.Status.Equals(statusFilter, StringComparison.OrdinalIgnoreCase));
        }

        // Apply sorting
        query = sortBy switch
        {
            "amount" => query.OrderByDescending(i => i.Amount),
            "client" => query.OrderBy(i => i.ClientName),
            _ => query.OrderBy(i => i.DueDate)
        };

        // Apply pagination
        var filtered = query.ToList();
        totalPages = (int)Math.Ceiling((double)filtered.Count / pageSize);
        
        return filtered
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void UpdatePagination()
    {
        var totalItems = Installments.Count;
        totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
        }
    }

    private void ResetFilters()
    {
        searchTerm = "";
        statusFilter = "all";
        sortBy = "dueDate";
        currentPage = 1;
    }

    private void TogglePaymentHistory(Guid id)
    {
        if (expandedInstallments.Contains(id))
            expandedInstallments.Remove(id);
        else
            expandedInstallments.Add(id);
    }

