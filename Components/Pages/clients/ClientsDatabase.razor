                Status = "Active",
                TotalLoans = 2,
                TotalLoanValue = 1800000,
                RegistrationDate = DateTime.Now.AddMonths(-7),
                Address = "101 Tech Park, Pretoria",
                IDNumber = "2019/456789/07"
            }
        };

        UpdatePagination();
    }

    private List<ClientViewModel> GetFilteredClients()
    {
        var query = Clients.AsQueryable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            query = query.Where(c => 
                c.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                c.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                c.ClientId.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                c.Phone.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                c.IDNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        // Apply type filter
        if (clientTypeFilter != "all")
        {
            var typeMapping = new Dictionary<string, string>
            {
                ["individual"] = "Individual",
                ["business"] = "Business",
                ["joint"] = "Joint"
            };
            if (typeMapping.ContainsKey(clientTypeFilter))
            {
                query = query.Where(c => c.Type == typeMapping[clientTypeFilter]);
            }
        }

        // Apply status filter
        if (statusFilter != "all")
        {
            query = query.Where(c => 
                c.Status.Equals(statusFilter, StringComparison.OrdinalIgnoreCase));
        }

        // Apply sorting
        query = sortBy switch
        {
            "date" => query.OrderByDescending(c => c.RegistrationDate),
            "loans" => query.OrderByDescending(c => c.TotalLoans),
            _ => query.OrderBy(c => c.Name)
        };

        // Apply pagination
        var filtered = query.ToList();
        totalPages = (int)Math.Ceiling((double)filtered.Count / pageSize);
        
        return filtered
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void UpdatePagination()
    {
        var totalItems = Clients.Count;
        totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
        }
    }

    private void ResetFilters()
    {
        searchTerm = "";
        clientTypeFilter = "all";
        statusFilter = "all";
        sortBy = "name";
        currentPage = 1;
    }

    private void FilterByType(string type = "individual")
    {
        clientTypeFilter = type;
        currentPage = 1;
    }

