    private int TotalLoans => Clients.Sum(c => c.TotalLoans);
    private decimal TotalLoanValue => Clients.Sum(c => c.TotalLoanValue);
    
    private decimal ActivePercentage => TotalClients > 0 ? Math.Round((decimal)ActiveClients / TotalClients * 100, 2) : 0;
    private decimal AverageLoansPerClient => TotalClients > 0 ? Math.Round((decimal)TotalLoans / TotalClients, 2) : 0;
    private decimal AverageLoanValue => TotalClients > 0 ? TotalLoanValue / TotalClients : 0;
    private double ClientGrowth => TotalClients > 0 ? Math.Round((double)TotalClients / 10 * 2.5, 2) : 0;
    private decimal LoanPercentage => TotalLoans > 0 ? Math.Min(100, Math.Round((decimal)TotalLoans / 50 * 100, 2)) : 0;
    private decimal ValuePercentage => TotalLoanValue > 0 ? Math.Min(100, Math.Round((decimal)TotalLoanValue / 5000000 * 100, 2)) : 0;

    // Type Distribution
