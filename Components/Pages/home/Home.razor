@page "/home"
@using BlazorApp.Components.Reusbale
@using BlazorApp.Models

<PageTitle>Home</PageTitle>

<div class="dashboard">
    <!-- welcome + stats -->
    <div class="welcome-stats">
        <div class="welcome-text">
            <h2>👋 Welcome back, Alex</h2>
            <p>Your trusted partner for smart lending.</p>
        </div>
        <div class="stats-group">
            <div class="stat-item">
                <i class="bi bi-cash-coin"></i>
                <div><span class="stat-number">4.2k</span> <span class="stat-label">loans funded</span></div>
            </div>
            <div class="stat-item">
                <i class="bi bi-star-fill"></i>
                <div><span class="stat-number">98%</span> <span class="stat-label">satisfaction</span></div>
            </div>
            <div class="stat-item">
                <i class="bi bi-lightning-charge"></i>
                <div><span class="stat-number">24h</span> <span class="stat-label">avg. approval</span></div>
            </div>
        </div>
    </div>

    <!-- loan offers -->
    <div class="section-title">
        <i class="bi bi-piggy-bank"></i> Loan offers
    </div>
    <div class="loan-grid">
        @foreach(var loaninfo in LoanInfos){
            <LoanCard 
                title="@loaninfo.Title" 
                description="@loaninfo.Description"
                icon="@loaninfo.Icon"
                smalldescription="@loaninfo.SmallDescription"/>
        }
    </div>

    <!-- why choose us -->
    <div class="section-title" style="margin-top: 0.5rem;">
        <i class="bi bi-award"></i> Why RockSolid
    </div>
    <div class="why-us">
        <div class="why-item">
            <i class="bi bi-shield-lock-fill"></i>
            <div>
                <h4>Secure & Trusted</h4>
                <p>Your data is safe with bank‑grade encryption.</p>
            </div>
        </div>
        <div class="why-item">
            <i class="bi bi-lightning-charge-fill"></i>
            <div>
                <h4>Fast Approval</h4>
                <p>Get a decision in minutes, not days.</p>
            </div>
        </div>
        <div class="why-item">
            <i class="bi bi-cash-coin"></i>
            <div>
                <h4>Competitive Rates</h4>
                <p>We offer some of the best APRs on the market.</p>
            </div>
        </div>
        <div class="why-item">
            <i class="bi bi-emoji-smile"></i>
            <div>
                <h4>24/7 Support</h4>
                <p>Real people, ready to help anytime.</p>
            </div>
        </div>
    </div>

    <div class="footer-note">
        <span><i class="bi bi-clock"></i> Last update: today &nbsp;·&nbsp; <i class="bi bi-lock-fill"></i> SSL secured</span>
    </div>

</div>

@code{
    private List<LoanInfo> LoanInfos = new()
    {
        new LoanInfo{
            Title="Personal Loan", 
            Description="Flexible amounts for any need.", 
            Icon="bi bi-person-fill", 
            SmallDescription="from 4.9% APR"
        },
        new LoanInfo{
            Title="House Loan", 
            Description="Mortgage & home renovation.", 
            Icon="bi bi-house-door-fill", 
            SmallDescription="from 3.2% APR"
        },
        new LoanInfo{
            Title="Car Loan", 
            Description="New & used vehicles..", 
            Icon="bi bi-car-front-fill", 
            SmallDescription="from 5.1% APR"
        }
    };

}