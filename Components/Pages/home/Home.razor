@page "/home"
<PageTitle>Home</PageTitle>

<div class="dashboard">
    <!-- welcome + stats -->
    <div class="welcome-stats">
        <div class="welcome-text">
            <h2>👋 Welcome back, Alex</h2>
            <p>Your trusted partner for smart lending.</p>
        </div>
        <div class="stats-group">
            <div class="stat-item">
                <i class="bi bi-cash-coin"></i>
                <div><span class="stat-number">4.2k</span> <span class="stat-label">loans funded</span></div>
            </div>
            <div class="stat-item">
                <i class="bi bi-star-fill"></i>
                <div><span class="stat-number">98%</span> <span class="stat-label">satisfaction</span></div>
            </div>
            <div class="stat-item">
                <i class="bi bi-lightning-charge"></i>
                <div><span class="stat-number">24h</span> <span class="stat-label">avg. approval</span></div>
            </div>
        </div>
    </div>

    <!-- loan offers -->
    <div class="section-title">
        <i class="bi bi-piggy-bank"></i> Loan offers
    </div>
    <div class="loan-grid">
        <!-- Personal -->
        <div class="loan-card">
            <div class="loan-icon"><i class="bi bi-person-fill"></i></div>
            <h3>Personal Loan</h3>
            <div class="loan-desc">Flexible amounts for any need.</div>
            <div class="loan-meta">
                <span class="loan-rate">from 4.9% APR</span>
                <button class="btn-apply" disabled><i class="bi bi-send"></i> Apply</button>
            </div>
        </div>
        <!-- House -->
        <div class="loan-card">
            <div class="loan-icon"><i class="bi bi-house-door-fill"></i></div>
            <h3>House Loan</h3>
            <div class="loan-desc">Mortgage & home renovation.</div>
            <div class="loan-meta">
                <span class="loan-rate">from 3.2% APR</span>
                <button class="btn-apply" disabled><i class="bi bi-send"></i> Apply</button>
            </div>
        </div>
        <!-- Car -->
        <div class="loan-card">
            <div class="loan-icon"><i class="bi bi-car-front-fill"></i></div>
            <h3>Car Loan</h3>
            <div class="loan-desc">New & used vehicles.</div>
            <div class="loan-meta">
                <span class="loan-rate">from 5.1% APR</span>
                <button class="btn-apply" disabled><i class="bi bi-send"></i> Apply</button>
            </div>
        </div>
    </div>

    <!-- why choose us -->
    <div class="section-title" style="margin-top: 0.5rem;">
        <i class="bi bi-award"></i> Why RockSolid
    </div>
    <div class="why-us">
        <div class="why-item">
            <i class="bi bi-shield-lock-fill"></i>
            <div>
                <h4>Secure & Trusted</h4>
                <p>Your data is safe with bank‑grade encryption.</p>
            </div>
        </div>
        <div class="why-item">
            <i class="bi bi-lightning-charge-fill"></i>
            <div>
                <h4>Fast Approval</h4>
                <p>Get a decision in minutes, not days.</p>
            </div>
        </div>
        <div class="why-item">
            <i class="bi bi-cash-coin"></i>
            <div>
                <h4>Competitive Rates</h4>
                <p>We offer some of the best APRs on the market.</p>
            </div>
        </div>
        <div class="why-item">
            <i class="bi bi-emoji-smile"></i>
            <div>
                <h4>24/7 Support</h4>
                <p>Real people, ready to help anytime.</p>
            </div>
        </div>
    </div>

    <div class="footer-note">
        <span><i class="bi bi-clock"></i> Last update: today &nbsp;·&nbsp; <i class="bi bi-lock-fill"></i> SSL secured</span>
    </div>

</div>
