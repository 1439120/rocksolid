@page "/home"
@using BlazorApp.Components.Reusbale
@using BlazorApp.Models
@inject ClientDatabaseService ClientDbService

<PageTitle>Home</PageTitle>

<div class="dashboard">
    <!-- welcome + stats -->
    <div class="welcome-stats">
        <div class="welcome-text">
            @if(User?.Name.Length > 0){
                <h2>👋 Welcome back, @User?.Name</h2>
                <p>Your trusted partner for smart lending.</p>
            }
            else{
                <p>World no #1 fastest lender</p>
            }
        </div>
        <div class="stats-group">
            <div class="stat-item">
                <i class="bi bi-cash-coin"></i>
                <div><span class="stat-number">4.2k</span> <span class="stat-label">loans funded</span></div>
            </div>
            <div class="stat-item">
                <i class="bi bi-star-fill"></i>
                <div><span class="stat-number">98%</span> <span class="stat-label">satisfaction</span></div>
            </div>
            <div class="stat-item">
                <i class="bi bi-lightning-charge"></i>
                <div><span class="stat-number">24h</span> <span class="stat-label">avg. approval</span></div>
            </div>
        </div>
    </div>

    <!-- loan offers -->
    <div class="section-title">
        <i class="bi bi-piggy-bank"></i> Loan offers
    </div>
    <div class="loan-grid">
        @foreach(var cardInfo in LoanInfos){
            <LoanCard 
                title="@cardInfo.Title" 
                description="@cardInfo.Description"
                icon="@cardInfo.Icon"
                smalldescription="@cardInfo.SmallDescription"/>
        }
    </div>

    <!-- why choose us -->
    <div class="section-title" style="margin-top: 0.5rem;">
        <i class="bi bi-award"></i> Why RockSolid
    </div>
    <div class="why-us">
        @foreach(var whyus in WhyusInfos){
            <WhyusCard 
            title="@whyus.Title" 
            description="@whyus.Description"
            icon="@whyus.Icon"/>
        }
    </div>

    <div class="footer-note">
        <span><i class="bi bi-clock"></i> Last update: today &nbsp;·&nbsp; <i class="bi bi-lock-fill"></i> SSL secured</span>
    </div>

</div>

@code{
    private ClientDatabase? User;
    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState{get; set;}
    protected override async Task OnInitializedAsync()
    {
        if(authenticationState != null){
            var authState = await authenticationState;
            var userClaims = authState.User;
            var userId = userClaims.FindFirst("UserId")?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                var users = await ClientDbService.GetClientByUserId(userId);
                User = users.FirstOrDefault();
            }
        }
    }
    private List<CardInfo> LoanInfos = new()
    {
        new CardInfo{
            Title="Personal Loan", 
            Description="Flexible amounts for any need.", 
            Icon="bi bi-person-fill", 
            SmallDescription="from 4.9% APR"
        },
        new CardInfo{
            Title="House Loan", 
            Description="Mortgage & home renovation.", 
            Icon="bi bi-house-door-fill", 
            SmallDescription="from 3.2% APR"
        },
        new CardInfo{
            Title="Car Loan", 
            Description="New & used vehicles..", 
            Icon="bi bi-car-front-fill", 
            SmallDescription="from 5.1% APR"
        }
    };

    private List<CardInfo> WhyusInfos = new()
    {
        new CardInfo{
            Title="Secure & Trusted", 
            Description="Your data is safe with bank‑grade encryption", 
            Icon="bi bi-shield-lock-fill", 
        },
        new CardInfo{
            Title="Fast Approval", 
            Description="Get a decision in minutes, not days.", 
            Icon="bi bi-lightning-charge-fill", 
        },
        new CardInfo{
            Title="Competitive Rates", 
            Description="We offer some of the best APRs on the market.", 
            Icon="bi bi-cash-coin", 
        },
        new CardInfo{
            Title="24/7 Support", 
            Description="Real people, ready to help anytime.", 
            Icon="bi bi-emoji-smile", 
        }
    };

}